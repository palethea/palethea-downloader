{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "description": "Palethea desktop downloader",
  "author": "Palethea",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "backend:dev": "cargo run --manifest-path native-backend/Cargo.toml",
    "backend:check": "cargo check --manifest-path native-backend/Cargo.toml",
    "backend:build": "cargo build --release --manifest-path native-backend/Cargo.toml",
    "deps:download": "npm run deps:download:ffmpeg && npm run deps:download:yt-dlp",
    "deps:download:ffmpeg": "node scripts/download-ffmpeg.mjs",
    "deps:download:yt-dlp": "node scripts/download-yt-dlp.mjs",
    "dev:web": "vite",
    "dev": "vite",
    "dev:app": "npm run desktop:dev",
    "dev:desktop": "npm run desktop:dev",
    "desktop:dev": "npm run deps:download && concurrently -k \"npm run dev -- --host 127.0.0.1 --port 5173\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "vite build",
    "desktop:prepare": "npm run deps:download && npm run backend:build && npm run build && node scripts/prepare-desktop.mjs",
    "desktop:pack": "npm run desktop:prepare && electron-builder --publish never",
    "desktop:pack:win": "npm run desktop:prepare && electron-builder --win nsis --publish never",
    "desktop:pack:linux": "npm run desktop:prepare && electron-builder --linux AppImage --publish never",
    "desktop:pack:mac": "npm run desktop:prepare && electron-builder --mac dmg --publish never",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.palethea.desktop",
    "productName": "Palethea",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Palethea-Setup-${version}.${ext}"
    },
    "linux": {
      "artifactName": "Palethea-${version}-${arch}.${ext}",
      "category": "Utility"
    },
    "mac": {
      "artifactName": "Palethea-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.4",
    "wait-on": "^8.0.5"
  }
}
